# =============================================
# CountTimeout 프로젝트 .gitignore
# macOS, Node.js, Cloudflare 환경 통합 제외 목록
# =============================================

# --- macOS 시스템 파일 (맥북 필수 제외) ---
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- Node.js 의존성 (절대 커밋 금지) ---
node_modules/
dist/
build/
.cache/
.parcel-cache/

# --- 환경변수 파일 (보안상 절대 업로드 금지) ---
# ⚠️ 중요: Google Client Secret, D1 토큰 등 민감정보가 담김
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.dev.vars

# --- Cloudflare 관련 ---
# wrangler 로컬 캐시 및 임시 파일
.wrangler/
*.wasm

# --- 로그 파일 ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 에디터 설정 (팀원마다 다를 수 있으므로 제외) ---
.vscode/
.idea/
*.swp
*.swo

# --- 테스트 커버리지 ---
coverage/
.nyc_output/
